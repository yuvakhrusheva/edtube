# =============================================================================
# YouTube Quize-Mode — переменные окружения BACKEND API
# =============================================================================
#
# Ключи LLM хранятся ТОЛЬКО на сервере. Расширение Chrome их не содержит.
#
# Как использовать:
#   1. Скопируйте этот файл:  cp .env.example .env
#   2. Заполните значения в .env
#   3. Убедитесь, что .env в .gitignore (уже добавлен)
#
# =============================================================================

# --- Ваш backend (расширение обращается сюда) -----------------------------

# Публичный URL API (будет прописан в extension background при интеграции)
API_BASE_URL=https://api.example.com

# Секрет для подписи session-token (JWT или аналог)
API_SESSION_SECRET=change-me-to-random-string

# Окружение: development | staging | production
NODE_ENV=development

# --- LLM-провайдер (на сервере) -------------------------------------------
# Активный провайдер: deepseek | openai | gemini
LLM_PROVIDER=deepseek

# Модель по умолчанию (зависит от провайдера)
LLM_MODEL=deepseek-chat

# --- DeepSeek (OpenAI-compatible API, рекомендуется для MVP) --------------
# Ключ: https://platform.deepseek.com → API Keys
# Endpoint: POST {DEEPSEEK_BASE_URL}/chat/completions

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Модели DeepSeek (актуальные ID — в доке platform.deepseek.com):
#   deepseek-chat      — быстрая генерация (quiz, MVP)
#   deepseek-reasoner  — с reasoning, дороже и медленнее
#   deepseek-v4-flash / deepseek-v4-pro — если доступны в аккаунте

# --- OpenAI (опционально) -------------------------------------------------

OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Google Gemini (опционально) ------------------------------------------

GEMINI_API_KEY=

# --- Helicone (опционально; в основном для OpenAI) ------------------------

HELICONE_API_KEY=
HELICONE_BASE_URL=https://oai.hconeai.com/v1

# --- Лимиты free tier -----------------------------------------------------

# Бесплатных вопросов на user_id в сутки
FREE_DAILY_QUESTION_LIMIT=5

# --- База данных (когда появится backend) ---------------------------------

# DATABASE_URL=postgresql://user:password@localhost:5432/quizemode
