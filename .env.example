# =============================================================================
# YouTube Quize-Mode — переменные окружения BACKEND API
# =============================================================================
#
# Ключи LLM хранятся ТОЛЬКО на сервере. Расширение Chrome их не содержит.
#
# Как использовать:
#   1. Скопируйте этот файл:  cp .env.example .env
#   2. Заполните значения в .env
#   3. Убедитесь, что .env в .gitignore (уже добавлен)
#
# =============================================================================

# --- Ваш backend (расширение обращается сюда) -----------------------------

# Публичный URL API (будет прописан в extension background при интеграции)
API_BASE_URL=http://localhost:3001

# Порт backend (локальная разработка)
PORT=3001

# Секрет для подписи session-token (JWT или аналог)
API_SESSION_SECRET=change-me-to-random-string

# Окружение: development | staging | production
NODE_ENV=development

# --- LLM через OpenRouter (OpenAI-compatible API) -------------------------
# Ключ: https://openrouter.ai/keys
# Endpoint: POST {OPENROUTER_BASE_URL}/chat/completions

LLM_PROVIDER=openrouter
LLM_MODEL=google/gemini-2.5-flash

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Опционально — отображается в рейтинге приложений на openrouter.ai
# OPENROUTER_HTTP_REFERER=https://your-app.example.com
# OPENROUTER_APP_TITLE=EdTube Quiz

# Другие модели Gemini на OpenRouter (см. https://openrouter.ai/models):
#   google/gemini-2.5-flash              — быстрая, рекомендуется для quiz
#   google/gemini-2.5-flash:thinking     — с reasoning, медленнее и дороже
#   google/gemini-2.5-pro                — качественнее, дороже

# --- Лимиты free tier -----------------------------------------------------

# Бесплатных вопросов на user_id в сутки
FREE_DAILY_QUESTION_LIMIT=5

# --- База данных (когда появится backend) ---------------------------------

# DATABASE_URL=postgresql://user:password@localhost:5432/quizemode
